NODE_ENV="production"
APP_URL="https://your-domain.vercel.app"

# Database Configuration (Vercel Postgres or Supabase)
DATABASE_URL="postgres://user:password@host/database?pgbouncer=true"
DIRECT_URL="postgres://user:password@host/database"

# Security
JWT_SECRET="generate-a-very-secure-random-string-here"
CRON_SECRET="generate-another-secure-random-string-here"

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Authentication (Google Cloud OAuth)
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id-here.apps.googleusercontent.com"
GOOGLE_CLIENT_ID="your-google-client-id-here.apps.googleusercontent.com"

# Email Delivery (Resend)
RESEND_API_KEY="re_123456789"
EMAIL_FROM="noreply@your-domain.com"

# Storage (Vercel Blob)
STORAGE_PROVIDER="vercel-blob"
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_123456789"
