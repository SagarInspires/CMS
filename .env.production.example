# EditorialFlow Production Environment Configuration
# Copy this file to .env.production and fill in the values before deploying.
# Do NOT commit .env.production to version control.

# Database Configuration (Required)
# Must point to your production PostgreSQL database.
POSTGRES_USER="editorial_user"
POSTGRES_PASSWORD="REPLACE_WITH_SECURE_PASSWORD"
POSTGRES_DB="editorialflow_prod"
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public"

# JWT Secret (Required)
# Must be a long, cryptographically secure random string (e.g., generated via `openssl rand -base64 32`)
JWT_SECRET="REPLACE_WITH_SECURE_RANDOM_STRING"

# Cron Secret (Required)
# Used to authenticate automated publishing requests.
CRON_SECRET="REPLACE_WITH_SECURE_RANDOM_STRING"

# Next.js Environment
NODE_ENV="production"
NEXT_TELEMETRY_DISABLED="1"
